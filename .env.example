# --- Robinhood ---
RH_USERNAME=your_robinhood_email
RH_PASSWORD=your_robinhood_password

# --- Live-trading guardrails (keep tiny while testing) ---
MAX_TRADE_DOLLARS=5
ALLOW_LIVE_TRADING=false

# --- AI decision layer ---
# Get a key at https://console.anthropic.com . If this is blank the bot still
# runs — it just falls back to a deterministic heuristic instead of Claude.
ANTHROPIC_API_KEY=
USE_AI_AGENT=true
AI_MODEL=claude-opus-4-8
AI_EFFORT=medium

# --- Risk engine (defaults are sensible; override only if you know why) ---
ACCOUNT_RISK_PER_TRADE_PCT=1.0
MAX_PORTFOLIO_HEAT_PCT=6.0
ATR_STOP_MULTIPLIER=2.0
ATR_TARGET_R_MULTIPLE=2.0
MAX_STOP_DISTANCE_PCT=8.0
TIME_STOP_DAYS=15
MAX_POSITIONS=5
EARNINGS_BLACKOUT_DAYS=3

# --- Screening thresholds ---
MIN_BUY_SCORE=70
MIN_WATCH_SCORE=55
